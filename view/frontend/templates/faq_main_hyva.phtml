        <script>
            function mageprinceFaq(config) {
                return {
                    ajaxUrl: config.ajaxUrl,
                    loading: false,
                    pageType: config.pageType,
                    pageTypeScroll: config.pageTypeScroll,
                    handleClick(event) {
                        const question = event.target.closest('[data-faq-question]');
                        if (!question || !this.$root.contains(question)) {
                            return;
                        }

                        this.toggleQuestion(question);
                    },
                    toggleQuestion(question) {
                        const answer = document.getElementById(question.getAttribute('aria-controls'));
                        if (!answer) {
                            return;
                        }

                        const isOpen = question.getAttribute('aria-expanded') === 'true';
                        this.setQuestionState(question, answer, !isOpen);
                    },
                    setQuestionState(question, answer, isOpen) {
                        question.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                        answer.style.display = isOpen ? '' : 'none';

                        const toggle = question.querySelector('.faq-toggle');
                        if (toggle) {
                            toggle.textContent = isOpen ? '-' : '+';
                        }
                    },
                    collapseAll() {
                        this.$root.querySelectorAll('[data-faq-question][aria-controls]').forEach((question) => {
                            const answer = document.getElementById(question.getAttribute('aria-controls'));
                            if (answer) {
                                this.setQuestionState(question, answer, false);
                            }
                        });
                    },
                    expandAll() {
                        this.$root.querySelectorAll('[data-faq-question][aria-controls]').forEach((question) => {
                            const answer = document.getElementById(question.getAttribute('aria-controls'));
                            if (answer) {
                                this.setQuestionState(question, answer, true);
                            }
                        });
                    },
                    selectGroup(groupId, targetSelector) {
                        if (this.pageType === this.pageTypeScroll) {
                            this.scrollTo(targetSelector);
                            return;
                        }

                        this.loading = true;
                        const formKey = window.hyva && typeof window.hyva.getFormKey === 'function'
                            ? window.hyva.getFormKey()
                            : (window.FORM_KEY || '');
                        const body = new URLSearchParams({groupId: groupId, hyva: '1'});
                        if (formKey) {
                            body.append('form_key', formKey);
                        }

                        fetch(this.ajaxUrl, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            body: body
                        })
                            .then((response) => response.json())
                            .then((response) => {
                                this.$refs.content.innerHTML = response.faq || '';
                                this.$nextTick(() => this.scrollTo(targetSelector));
                            })
                            .finally(() => {
                                this.loading = false;
                            });
                    },
                    scrollTo(targetSelector) {
                        const target = document.querySelector(targetSelector);
                        if (target) {
                            target.scrollIntoView({behavior: 'smooth', block: 'start'});
                        }
                    }
                };
            }
        </script>
    <?php else: ?>
